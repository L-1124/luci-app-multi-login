#!/bin/sh

# rpcd handler for multilogin plugin
# Exposed as ubus object "multilogin" with methods:
#   quick_setup    - Generate macvlan + network + firewall + mwan4 config
#   list_auto      - List all auto_* managed sections
#   remove_auto    - Remove all auto_* managed sections

cleanup_auto_network() {
    for section in $(uci show network 2>/dev/null | grep -oE '^network\.[^.]+' | sort -u); do
        name="${section#network.}"
        case "$name" in auto_*) uci -q delete "network.$name" ;; esac
    done
}

cleanup_auto_mwan4() {
    for section in $(uci show mwan4 2>/dev/null | grep -oE '^mwan4\.[^.]+' | sort -u); do
        name="${section#mwan4.}"
        case "$name" in auto_*) uci -q delete "mwan4.$name" ;; esac
    done

    for route in $(uci -q get mwan4.balanced.use_route 2>/dev/null); do
        case "$route" in auto_*) uci del_list "mwan4.balanced.use_route=$route" ;; esac
    done
}

cleanup_auto_firewall() {
    WAN_ZONE=""
    for z in $(uci show firewall | grep '=zone' | grep -oE 'firewall\.[^=]+=zone' | awk -F= '{print $1}' | awk -F. '{print $2}'); do
        if [ "$(uci -q get "firewall.$z.name")" = "wan" ]; then
            WAN_ZONE="$z"
            break
        fi
    done

    if [ -n "$WAN_ZONE" ]; then
        for net in $(uci -q get "firewall.$WAN_ZONE.network"); do
            case "$net" in auto_*) uci del_list "firewall.$WAN_ZONE.network=$net" ;; esac
        done
    fi
}

ensure_mwan4_base() {
    uci -q get mwan4.globals >/dev/null 2>&1 || uci set mwan4.globals=globals
    uci -q get mwan4.globals.mmx_mask >/dev/null 2>&1 || uci set mwan4.globals.mmx_mask='0x3F00'

    uci -q get mwan4.balanced >/dev/null 2>&1 || uci set mwan4.balanced=strategy

    uci -q get mwan4.default_rule_v4 >/dev/null 2>&1 || uci set mwan4.default_rule_v4=rule
    uci set mwan4.default_rule_v4.dest_ip='0.0.0.0/0'
    uci set mwan4.default_rule_v4.use_strategy='balanced'
    uci del mwan4.default_rule_v4.family 2>/dev/null
    uci add_list mwan4.default_rule_v4.family='ipv4'
}

case "$1" in
    list)
        printf '{"quick_setup":{"base_iface":"","count":0},"list_auto":{},"remove_auto":{}}\n'
        ;;
    call)
        case "$2" in
            quick_setup)
                json=$(cat)
                BASE_IF=$(echo "$json" | jsonfilter -e '@.base_iface' 2>/dev/null)
                COUNT=$(echo "$json" | jsonfilter -e '@.count' 2>/dev/null)

                if [ -z "$BASE_IF" ] || [ -z "$COUNT" ] || [ "$COUNT" -lt 1 ] 2>/dev/null; then
                    printf '{"error":"invalid parameters: base_iface and count are required"}\n'
                    exit 1
                fi

                cleanup_auto_network
                cleanup_auto_mwan4
                cleanup_auto_firewall
                ensure_mwan4_base

                i=1
                while [ "$i" -le "$COUNT" ]; do
                    MACVLAN_DEV="auto_${BASE_IF}_${i}"
                    LOGICAL_IF="auto_vwan_${i}"
                    MWAN_ROUTE="auto_vwan_${i}_m1_w5"
                    METRIC=$((10 + i))

                    uci set "network.$MACVLAN_DEV=device"
                    uci set "network.$MACVLAN_DEV.type=macvlan"
                    uci set "network.$MACVLAN_DEV.ifname=$BASE_IF"
                    uci set "network.$MACVLAN_DEV.name=$MACVLAN_DEV"
                    uci set "network.$MACVLAN_DEV.mode=private"
                    uci set "network.$MACVLAN_DEV.ipv6=0"

                    uci set "network.$LOGICAL_IF=interface"
                    uci set "network.$LOGICAL_IF.proto=dhcp"
                    uci set "network.$LOGICAL_IF.device=$MACVLAN_DEV"
                    uci set "network.$LOGICAL_IF.metric=$METRIC"

                    if [ -n "$WAN_ZONE" ]; then
                        uci add_list "firewall.$WAN_ZONE.network=$LOGICAL_IF"
                    fi

                    uci set "mwan4.$LOGICAL_IF=interface"
                    uci set "mwan4.$LOGICAL_IF.enabled=1"
                    uci del "mwan4.$LOGICAL_IF.family" 2>/dev/null
                    uci add_list "mwan4.$LOGICAL_IF.family=ipv4"
                    uci del "mwan4.$LOGICAL_IF.track_ip" 2>/dev/null
                    uci add_list "mwan4.$LOGICAL_IF.track_ip=223.5.5.5"
                    uci add_list "mwan4.$LOGICAL_IF.track_ip=114.114.114.114"
                    uci set "mwan4.$LOGICAL_IF.reliability=1"

                    uci set "mwan4.$MWAN_ROUTE=route"
                    uci set "mwan4.$MWAN_ROUTE.interface=$LOGICAL_IF"
                    uci set "mwan4.$MWAN_ROUTE.metric=1"
                    uci set "mwan4.$MWAN_ROUTE.weight=5"

                    uci add_list "mwan4.balanced.use_route=$MWAN_ROUTE"
                    i=$((i + 1))
                done

                uci commit network
                uci commit firewall
                uci commit mwan4

                /etc/init.d/network reload >/dev/null 2>&1 &
                /etc/init.d/firewall reload >/dev/null 2>&1 &
                /etc/init.d/mwan4 restart >/dev/null 2>&1 &

                printf '{"result":"ok","count":%s,"base_iface":"%s"}\n' "$COUNT" "$BASE_IF"
                ;;

            list_auto)
                IFACES=$(uci show network | grep -E '^network\.auto_[^.=]+=interface$' | sed 's/network\.\([^.=]*\)=interface/\1/' | sort -u)
                DEVICES=$(uci show network | grep -E '^network\.auto_[^.=]+=device$' | sed 's/network\.\([^.=]*\)=device/\1/' | sort -u)

                FIRST_DEV=$(echo "$DEVICES" | head -n1)
                BASE_IF=""
                COUNT=0
                if [ -n "$FIRST_DEV" ]; then
                    BASE_IF=$(uci -q get "network.$FIRST_DEV.ifname" 2>/dev/null)
                    COUNT=$(echo "$IFACES" | grep -c .)
                fi

                printf '{"base_iface":"%s","count":%s,"interfaces":[' "$BASE_IF" "$COUNT"
                first=1
                for iface in $IFACES; do
                    dev=$(uci -q get "network.$iface.device" 2>/dev/null)
                    metric=$(uci -q get "network.$iface.metric" 2>/dev/null)
                    [ "$first" = "1" ] && first=0 || printf ','
                    printf '{"name":"%s","device":"%s","metric":"%s"}' "$iface" "$dev" "$metric"
                done
                printf ']}\n'
                ;;

            remove_auto)
                cleanup_auto_network
                cleanup_auto_mwan4
                cleanup_auto_firewall

                uci commit network
                uci commit firewall
                uci commit mwan4

                /etc/init.d/network reload >/dev/null 2>&1 &
                /etc/init.d/firewall reload >/dev/null 2>&1 &
                /etc/init.d/mwan4 restart >/dev/null 2>&1 &

                printf '{"result":"ok"}\n'
                ;;

            *)
                printf '{"error":"unknown method"}\n'
                exit 1
                ;;
        esac
        ;;
    *)
        printf '{"error":"unsupported action"}\n'
        exit 1
        ;;
esac
