{
    "luci-app-multi-login": {
        "description": "Grant access to multilogin configuration",
        "read": {
            "uci": [
                "multilogin",
                "network",
                "firewall",
                "mwan4"
            ],
            "file": [
                "/etc/multilogin/*",
                "/var/log/multilogin.log"
            ],
            "ubus": {
                "luci": [
                    "getInitList"
                ],
                "service": [
                    "list"
                ],
                "multilogin": [
                    "list_auto"
                ],
                "mwan4": [
                    "status"
                ]
            }
        },
        "write": {
            "uci": [
                "multilogin",
                "network",
                "firewall",
                "mwan4"
            ],
            "file": [
                "/etc/multilogin/login.sh",
                "/etc/multilogin/login_A.sh",
                "/etc/multilogin/login_huxi.sh"
            ],
            "ubus": {
                "luci": [
                    "setInitAction"
                ],
                "file": [
                    "write",
                    "read"
                ],
                "multilogin": [
                    "quick_setup",
                    "remove_auto"
                ]
            }
        }
    }
}
